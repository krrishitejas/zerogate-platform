# (Optional) Groq API
# Fast Llama 3 70B inference
# GROQ_API_KEY=""

# ==========================================
# ⚙️ Basic System Configuration
# ==========================================

PORT=8000
JWT_SECRET="zerogate_super_secret_override_me"

